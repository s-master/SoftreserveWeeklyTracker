@model SoftreserveTracker.Web.Models.ViewModels.CreateRosterViewModel
@{
    ViewData["Title"] = Localizer["Home_Title"];
}

<div class="page-header">
    <h1 class="h2 d-flex align-items-center gap-2">
        <img src="~/img/logo.png" alt="" class="navbar-logo" asp-append-version="true" />
        @Localizer["Home_Title"]
    </h1>
    <p class="text-secondary mb-0">@Localizer["Home_Subtitle"]</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card-softres p-4">
            <h2 class="h5 mb-3">@Localizer["Home_CreateRoster"]</h2>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">@Localizer["Home_RosterName"]</label>
                    <input asp-for="Name" class="form-control" placeholder="Raid Team" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-accent">
                    <i class="fa-solid fa-plus me-1"></i>@Localizer["Home_CreateButton"]
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
